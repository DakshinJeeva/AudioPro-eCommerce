{
  "name": "audiopro-backend",
  "version": "1.0.0",
  "description": "AudioPro eCommerce – Node.js backend (monolith + microservices)",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "start:user": "node user-service/server.js",
    "start:product": "node product-service/server.js",
    "start:order": "node order-service/server.js",
    "start:mcp": "node mcp-service/server.js",
    "start:mcp:stdio": "node mcp-service/mcp_server.js",
    "dev:user": "nodemon user-service/server.js",
    "dev:product": "nodemon product-service/server.js",
    "dev:order": "nodemon order-service/server.js",
    "dev:mcp": "nodemon mcp-service/server.js",
    "dev:all": "concurrently \"npm run dev:user\" \"npm run dev:product\" \"npm run dev:order\" \"npm run dev:mcp\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/sdk": "^0.12.35",
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-async-handler": "^1.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.19.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.10",
    "openai": "^6.37.0",
    "stripe": "^19.3.0",
    "twilio": "^5.10.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.10"
  }
}
