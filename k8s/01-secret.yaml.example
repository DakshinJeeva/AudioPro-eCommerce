# ──────────────────────────────────────────────────────────────────────────────
# k8s/01-secret.yaml.example
#
# TEMPLATE — commit this file.  DO NOT commit 01-secret.yaml.
#
# To create your local secret file:
#   cp k8s/01-secret.yaml.example k8s/01-secret.yaml
#   # then fill in each <REPLACE_ME> with the real value
#   kubectl apply -f k8s/01-secret.yaml
#
# All values use `stringData` so you can paste plain-text — Kubernetes
# base64-encodes them automatically when the Secret is created.
# ──────────────────────────────────────────────────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: audiopro-secret
  namespace: audiopro
type: Opaque
stringData:
  # ── Ports ─────────────────────────────────────────────────────────────────
  USER_SERVICE_PORT: "5001"
  PRODUCT_SERVICE_PORT: "5002"
  ORDER_SERVICE_PORT: "5003"
  MCP_SERVICE_PORT: "5004"

  # ── MongoDB ───────────────────────────────────────────────────────────────
  MONGO_URI: "<REPLACE_ME>"           # mongodb+srv://user:pass@cluster.mongodb.net/...

  # ── JWT ───────────────────────────────────────────────────────────────────
  JWT_SECRET: "<REPLACE_ME>"          # long random hex string
  JWT_EXPIRES_IN: "7d"

  # ── Email / SendGrid ──────────────────────────────────────────────────────
  CONTACT_EMAIL_USER: "<REPLACE_ME>"  # your Gmail address
  CONTACT_EMAIL_PASS: "<REPLACE_ME>"  # Gmail app password
  SENDGRID_API_KEY: "<REPLACE_ME>"    # SG.xxxxxxxx...
  SENDGRID_FROM_EMAIL: "<REPLACE_ME>"

  # ── Stripe ────────────────────────────────────────────────────────────────
  STRIPE_SECRET_KEY: "<REPLACE_ME>"   # sk_test_... or sk_live_...
  VITE_STRIPE_KEY: "<REPLACE_ME>"     # pk_test_... or pk_live_...

  # ── Twilio ────────────────────────────────────────────────────────────────
  TWILIO_ACCOUNT_SID: "<REPLACE_ME>"  # ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
  TWILIO_AUTH_TOKEN: "<REPLACE_ME>"
  TWILIO_FROM_NUMBER: "<REPLACE_ME>"  # +1xxxxxxxxxx

  # ── OpenRouter (AI) ───────────────────────────────────────────────────────
  OPENROUTER_API_KEY: "<REPLACE_ME>"  # sk-or-v1-...

  # ── Frontend service URLs (Kubernetes ClusterIP DNS names) ────────────────
  FRONTEND_URL: "http://frontend:5173"
  VITE_USER_API_URL: "http://user-service:5001"
  VITE_PRODUCT_API_URL: "http://product-service:5002"
  VITE_ORDER_API_URL: "http://order-service:5003"
  VITE_MCP_API_URL: "http://mcp-service:5004"
